{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpudKit",
  "version": "0.1.0",
  "identifier": "com.spudkit.app",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; connect-src spudkit://localhost"
    }
  }
}
